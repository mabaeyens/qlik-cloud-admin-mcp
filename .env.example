# Copy this file to .env and fill in your values.
# If QLIK_API_KEY is left empty, qlik-cli will use its configured context credentials instead.
QLIK_API_KEY=your_api_key_here

# Required for qlikcloud_create_app_from_data_product.
# Your Qlik Cloud tenant URL, no trailing slash. Example: https://your-tenant.eu.qlikcloud.com
QLIK_TENANT_URL=https://your-tenant.eu.qlikcloud.com
